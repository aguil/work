{
  "name": "workctl",
  "version": "0.1.0",
  "description": "Agent workspace manager for tmux",
  "type": "module",
  "bin": {
    "workctl": "./dist/workctl.mjs",
    "workctld": "./dist/workctld.mjs"
  },
  "scripts": {
    "build": "node build.mjs",
    "dev": "node build.mjs --watch",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "bash scripts/test-phase1.sh && bash scripts/test-phase2.sh && bash scripts/test-phase3.sh && bash scripts/test-phase4.sh && bash scripts/test-phase5.sh && bash scripts/test-phase6.sh",
    "pre-commit": "bash scripts/pre-commit.sh",
    "check": "npm run typecheck && npm run lint && npm run build && npm run test"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT",
  "dependencies": {
    "commander": "^13.1.0",
    "smol-toml": "^1.3.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@types/node": "^22.15.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.8.0"
  }
}
