{
  "name": "workctl",
  "version": "0.1.0",
  "description": "Agent workspace manager for tmux",
  "type": "module",
  "bin": {
    "workctl": "./dist/workctl.mjs",
    "workctld": "./dist/workctld.mjs"
  },
  "scripts": {
    "build": "node build.mjs",
    "dev": "node build.mjs --watch",
    "typecheck": "tsc --noEmit",
